# RepoMirror — Environment Configuration
# Copy this file to .env and fill in your values, OR run ./setup.sh
# to have everything configured interactively.
#
# NEVER commit .env to version control.

# ── Core ──────────────────────────────────────────────────────────────────────
# Your public domain for Forgejo (e.g. repos.yourdomain.com)
DOMAIN=repos.example.com

# Networking mode: tunnel | direct | local
NET_MODE=tunnel

# Cloudflare Tunnel ID (only required if NET_MODE=tunnel)
TUNNEL_ID=

# Override the Forgejo root URL (auto-set by setup.sh)
# For local mode this should be http://localhost:3000
FORGEJO_ROOT_URL=https://repos.example.com

# Timezone for containers (e.g. America/New_York, Europe/London)
TZ=UTC

# ── GitHub ────────────────────────────────────────────────────────────────────
# Your GitHub username
GITHUB_USER=your-github-username

# Fine-grained PAT — create at https://github.com/settings/tokens
# Required permissions: Contents: Read, Metadata: Read (all repositories)
GITHUB_TOKEN=github_pat_...

# ── Forgejo Admin Account ─────────────────────────────────────────────────────
FORGEJO_ADMIN_USER=admin
FORGEJO_ADMIN_EMAIL=you@example.com
FORGEJO_ADMIN_PASSWORD=changeme_use_a_strong_password

# Forgejo API token (auto-generated by setup.sh)
FORGEJO_TOKEN=

# ── Webhook Relay ─────────────────────────────────────────────────────────────
# Shared secret between GitHub webhooks and the relay (auto-generated by setup.sh)
WEBHOOK_SECRET=

# ── Backup ────────────────────────────────────────────────────────────────────
# 1 = none, 2 = local, 3 = S3-compatible
BACKUP_MODE=1

# Local backup path (BACKUP_MODE=2)
BACKUP_DIR=

# S3-compatible settings (BACKUP_MODE=3)
# Backblaze B2 example endpoint: https://s3.us-west-004.backblazeb2.com
# Leave S3_ENDPOINT blank for AWS S3
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Watchtower update notifications (shoutrrr URL)
# Examples: slack://token@channel   smtp://user:pass@host:587/?from=a&to=b
WATCHTOWER_NOTIFICATION_URL=
