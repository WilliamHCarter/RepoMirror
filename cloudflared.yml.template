# RepoMirror — Cloudflare Tunnel config
# Generated by setup.sh.

tunnel: {{TUNNEL_ID}}
credentials-file: {{CRED_FILE}}

ingress:
  # Forgejo web UI, API, and git-over-HTTP
  - hostname: {{DOMAIN}}
    service: http://forgejo:3000

  # Catch-all (required by cloudflared)
  - service: http_status:404
